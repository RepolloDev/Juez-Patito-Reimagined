---
import '@fontsource/major-mono-display'
import '@fontsource/geist-sans/400.css'
import '@fontsource/geist-sans/600.css'
import '@fontsource/geist-sans/800.css'
import '@fontsource-variable/victor-mono'
import '@fontsource/gloria-hallelujah'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Juez Patito Reimagined es una reconstrucción FrontEnd de una página del mismo, una alternativa moderna con un diseño fresco y renovado"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://jpr.vercel.app/" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <style is:global>
      html {
        font-family: 'Geist Sans', sans-serif;
      }
      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      code {
        font-family: 'Victor Mono Variable', monospace;
      }
    </style>
    <slot />
  </body>
</html>
