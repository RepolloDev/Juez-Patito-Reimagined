<style>
  .rainbow-text {
    color: transparent;
    background-image: linear-gradient(
      90deg,
      theme('colors.error'),
      theme('colors.success'),
      theme('colors.info'),
      theme('colors.warning'),
      theme('colors.error')
    );
    background-size: 200%;
    background-clip: text;
    animation: rainbow 5s linear infinite;
  }

  @keyframes rainbow {
    0% {
      background-position: 0%;
    }
    100% {
