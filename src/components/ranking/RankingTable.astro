---
import type { UserRank } from '@utils/content/ranking'
import Avatar from '@components/Avatar.astro'

interface Props {
  rankList: UserRank[]
  class?: string
}

const { rankList, class: className } = Astro.props
---

<div class="overflow-x-auto" class:list={[className]}>
  <table class="table">
    <!-- head -->
    <thead>
      <tr>
        <th class="text-center">Rank</th>
        <th>Usuario</th>
        <th>Aceptados</th>
        <th>Enviados</th>
      </tr>
    </thead>
    <tbody>
      <!-- row -->
      {
        rankList.map((user, index) => {
          return (
            <tr>
              <th class="flex justify-center items-center">{index + 1}</th>
              <td>
                <div class="flex items-center gap-3">
                  <div class="avatar">
                    <div class="mask mask-squircle w-10 h-10 xl:w-12 xl:h-12">
                      <Avatar name={user.nick} />
                    </div>
                  </div>
                  <div>
                    <div class="font-bold">{user.user_id}</div>
                    <div class="text-sm opacity-50">{user.nick}</div>
                  </div>
                </div>
              </td>
              <td>{user.solved}</td>
              <td>{user.submit}</td>
            </tr>
          )
        })
      }
    </tbody>
    <!-- foot -->
    <tfoot>
      <tr>
        <th>Rank</th>
        <th>Usuario</th>
        <th>Aceptados</th>
        <th>Enviados</th>
      </tr>
    </tfoot>
  </table>
</div>
