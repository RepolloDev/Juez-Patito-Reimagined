{
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#616587",
    "activityBar.background": "#616587",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#4a3538",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#616587",
    "statusBar.background": "#4c4f69",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#616587",
    "statusBarItem.remoteBackground": "#4c4f69",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#4c4f69",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#4c4f6999",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#4c4f69",
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "astro", // Enable .astro
    "typescript", // Enable .ts
    "typescriptreact" // Enable .tsx
  ],
  "prettier.documentSelectors": ["**/*.astro"],
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },
  "cSpell.words": [
    "aling",
    "Alings",
    "astro",
    "astrojs",
    "daisyui",
    "derecho",
    "izquierdo",
    "nanostores",
    "tailwindcss"
  ],
  "cSpell.enabled": false
}
